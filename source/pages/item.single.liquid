---
pagination:
  data: generated.items.single
  size: 1
  alias: paginated
layout: default
permalink: /{{ paginated.package.slug }}/{{ paginated.type.plural }}/{{ paginated.name.slug }}/index.html
---
<h1>{{ paginated.name.original }}</h1>

{% if paginated.type.singular == 'class' %}
  {% assign item = generated[paginated.package.original].classes.map[paginated.name.original] %}
  {{ item.self.declaration.comment.summary | markdown }}
  {% for type in generated.classes.types %}
    {% assign label = type.plural | capitalize %}
    {% render 'details.liquid', items: item[type.plural].array, label: label %}
  {% endfor %}
{% else %}
  {% assign item = generated[paginated.package.original][paginated.type.plural].map[paginated.name.original] %}

  {% if paginated.type.singular == 'function' %}
    {% render 'callable.liquid', item: item, page: page, paginated: paginated %}
  {% elsif paginated.type.singular == 'model' %}
    {% render 'model.liquid', item: item, page: page, paginated: paginated %}
  {% endif %}
{% endif %}
